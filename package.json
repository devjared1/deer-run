{
  "name": "deer-run",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:pages": "npm run dev:pages --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "deploy": "npm run deploy --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web && npm run lint --workspace=apps/api",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api",
    "db:studio": "npm run studio --workspace=apps/api"
  },
  "dependencies": {
    "vue-dompurify-html": "^5.3.0"
  }
}
